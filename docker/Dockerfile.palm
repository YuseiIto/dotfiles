FROM debian:bookworm-slim@sha256:0104b334637a5f19aa9c983a91b54c89887c0984081f2068983107a6f6c21eeb

LABEL org.opencontainers.image.source=https://github.com/yuseiito/dotfiles
LABEL org.opencontainers.image.description="Yusei's dotfiles Container. Variant `palm`"
LABEL org.opencontainers.image.licenses=MIT

# Suppress interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Minimal setup before running setup.sh
RUN apt-get update && \
    apt-get install -y sudo curl ca-certificates tar

# Allow passwordless sudo for the debian user
ARG USER_UID=1000
ARG USER_GID=$USER_UID
RUN groupadd --gid $USER_GID debian && \
    useradd --uid $USER_UID --gid $USER_GID -m -s /bin/bash debian && \
    echo "debian ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/debian && \
    chmod 0440 /etc/sudoers.d/debian


USER debian
ENV HOME=/home/debian
ENV USER=debian
ENV LOGNAME=debian
ENV LANG=C.UTF-8
ENV TZ=Asia/Tokyo
ENV SHELL=/usr/bin/bash

COPY --chown=debian:debian ./ /home/debian/dotfiles/
WORKDIR /home/debian/dotfiles/

RUN sudo apt-get update

ENV DOTFILES_ROLE=palm
RUN bash ./setup.sh && \
    sudo install -m 755 docker/entrypoint.palm.sh /usr/local/bin/entrypoint.sh

WORKDIR /home/debian

HEALTHCHECK --interval=60s --timeout=30s --start-period=5s --retries=3 \
    CMD ["/usr/local/bin/entrypoint.sh", "goss", "--gossfile", "/home/debian/dotfiles/mitamae/roles/palm/goss.yaml", "validate"]

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["/usr/bin/bash"]
