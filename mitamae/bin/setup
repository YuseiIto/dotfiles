#!/bin/bash
set -euo pipefail

# Resolve paths relative to this script so it can be invoked from any cwd
cd "$(dirname "$0")/.."

mitamae_version="2.0.0"

mitamae_bin="mitamae-${mitamae_version}"

platform=$(uname | tr '[:upper:]' '[:lower:]')
arch=$(uname -m)

# This project targets macOS and Debian-based Linux only; fail early with a
# clear message instead of a cryptic 404 from the release download below
if [ "$platform" != "linux" ] && [ "$platform" != "darwin" ]; then
	echo "Unsupported platform: $platform"
	exit 1
fi

if [ "$arch" = "amd64" ] || [ "$arch" = "x86_64" ]; then
	arch="x86_64"
elif [ "$arch" = "arm64" ] || [ "$arch" = "aarch64" ]; then
	arch="aarch64"
else
	echo "Unsupported architecture: $arch"
	exit 1
fi

# Check if the mitamae binary is already present in the bin directory
if ! [ -f "bin/${mitamae_bin}" ]; then
	# NOTE: Since v2.0.0 the release ships the stripped binary as a raw, uncompressed
	# asset (mitamae-<arch>-<os>) rather than a .tar.gz; only the *.debug files are
	# gzipped. Downloading a .tar.gz therefore 404s.
	# Ref: https://github.com/itamae-kitchen/mitamae/releases/tag/v2.0.0
	mitamae_download_name="mitamae-${arch}-${platform}"
	mitamae_binary_url="https://github.com/itamae-kitchen/mitamae/releases/download/v${mitamae_version}/${mitamae_download_name}"

	curl -o "bin/${mitamae_bin}" -fL "$mitamae_binary_url"

	# Make the mitamae binary executable
	chmod +x "bin/${mitamae_bin}"
fi

# Create a symbolic link to the mitamae binary in the bin directory
ln -sf "${mitamae_bin}" bin/mitamae
