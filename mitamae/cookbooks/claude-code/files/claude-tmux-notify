#!/bin/sh
# Raise @claude_notif tmux window option when Claude Code needs user input.
# Cleared by tmux pane-focus-in / after-select-window hooks (see tmux.conf).
# Skip only while the user is viewing this pane: pane_active alone stays 1 after
# switching windows, so window_active is required to detect a backgrounded pane.

[ -n "$TMUX_PANE" ] || exit 0

viewing=$(tmux display-message -p -t "$TMUX_PANE" '#{&&:#{pane_active},#{window_active}}' 2>/dev/null)
[ "$viewing" = "1" ] && exit 0

tmux set-option -t "$TMUX_PANE" -w @claude_notif 1 >/dev/null
