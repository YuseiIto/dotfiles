{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read(~/.zshrc)",
      "Read(~/.bashrc)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(git add *)",
      "Bash(git status *)",
      "Bash(git grep *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git shortlog *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue comment *)",
      "Bash(cargo search *)",
      "Bash(cargo info *)",
      "Bash(cargo download *)",
      "Bash(cargo doc *)",
      "Bash(cargo check *)",
      "Bash(cargo build *)",
      "Bash(cargo test *)",
      "Bash(cargo clean *)",
      "Bash(cargo test *)",
      "Bash(cargo update *)",
      "Bash(cargo bench *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fix *)",
      "Bash(cargo fmt *)",
      "Bash(cargo metadata *)",
      "Bash(cargo package *)",
      "Bash(cargo rustdoc *)",
      "Bash(cargo tree *)",
      "Bash(npm audit *)",
      "Bash(npm ci *)",
      "Bash(npm ls *)",
      "Bash(npm outdated *)",
      "Bash(npm prune *)",
      "Bash(npm update *)",
      "Bash(npm help *)",
      "Bash(npm test *)",
      "Bash(uv init *)",
      "Bash(uv version *)",
      "Bash(uv tree *)",
      "Bash(uv format *)",
      "Bash(uv audit *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.dev.vars)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git checkout .)",
      "Bash(git clean -f *)",
      "Bash(npm publish *)",
      "Bash(yarn publish *)",
      "Bash(pnpm publish *)",
      "Bash(cargo publish *)",
      "Bash(uv publish *)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(npm logout *)",
      "Bash(npm login *)",
      "Bash(uv auth *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(docker push *)"
    ],
    "ask": [
      "Bash(git reset --hard *)",
      "Bash(git push --force-with-lease *)"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pm-data-analytics@pm-skills": true,
    "pm-execution@pm-skills": true,
    "pm-go-to-market@pm-skills": true,
    "pm-market-research@pm-skills": true,
    "pm-marketing-growth@pm-skills": true,
    "pm-product-discovery@pm-skills": true,
    "pm-product-strategy@pm-skills": true,
    "pm-toolkit@pm-skills": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "pm-skills": {
      "source": {
        "source": "github",
        "repo": "phuryn/pm-skills"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark",
  "agentPushNotifEnabled": true
}
