{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":gitSignOff"
  ],
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update mitamae version in bin/setup",
      "managerFilePatterns": ["/^mitamae/bin/setup$/"],
      "matchStrings": ["mitamae_version=\"(?<currentValue>.*?)\""],
      "depNameTemplate": "itamae-kitchen/mitamae",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Update goss version in cookbooks/goss/default.rb",
      "managerFilePatterns": ["/^mitamae/cookbooks/goss/default.rb$/"],
      "matchStrings": ["goss_version = '(?<currentValue>.*?)'"],
      "depNameTemplate": "goss-org/goss",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "description": "Group devcontainer feature updates",
      "matchManagers": ["devcontainer"],
      "groupName": "devcontainer-features",
      "automerge": true
    },
    {
      "description": "Group Docker base image updates",
      "matchManagers": ["dockerfile"],
      "groupName": "docker-base-images"
    },
    {
      "description": "Group bundler (Gemfile) updates",
      "matchManagers": ["bundler"],
      "groupName": "bundler"
    }
  ]
}
