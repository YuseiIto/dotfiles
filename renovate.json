{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":gitSignOff", ":semanticCommits", "schedule:weekly"],
  "labels": ["dependencies"],
  "assignees": ["yuseiito"],
  "dependencyDashboard": true,
  "prHourlyLimit": 0,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Group and automerge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "description": "Group and automerge devcontainer feature updates",
      "matchManagers": ["devcontainer"],
      "groupName": "devcontainer-features",
      "automerge": true
    },
    {
      "description": "Group Docker base image updates (reviewed, not automerged)",
      "matchManagers": ["dockerfile"],
      "groupName": "docker-base-images"
    },
    {
      "description": "Group bundler (Gemfile) updates and automerge non-major ones",
      "matchManagers": ["bundler"],
      "groupName": "bundler",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Keep major bundler updates as a separate reviewed PR",
      "matchManagers": ["bundler"],
      "matchUpdateTypes": ["major"],
      "groupName": "bundler (major)"
    }
  ]
}
